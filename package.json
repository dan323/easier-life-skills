{
  "name": "easier-life-skills",
  "private": true,
  "type": "module",
  "workspaces": [
    "installer"
  ],
  "scripts": {
    "build": "tsx scripts/build-index.ts && esbuild assets/src/app.ts --bundle --outfile=assets/bundle.js --format=esm",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.web.json",
    "publish:installer": "npm publish --workspace installer --access public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
